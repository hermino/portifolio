{
  "name": "hermino-portfolio",
  "version": "1.0.0",
  "description": "Frontend Developer Portfolio - Hermino Freitas (Angular Version)",
  "scripts": {
    "ng": "ng",
    "start": "concurrently \"npm run start:landpage\" \"npm run start:admin\"",
    "start:landpage": "ng serve landpage",
    "start:admin": "ng serve admin",
    "build": "npm run build:landpage && npm run build:admin",
    "build:landpage": "ng build landpage --configuration production --base-href /",
    "build:admin": "ng build admin --configuration production --base-href /admin/",
    "build:gh-pages": "ng build landpage --configuration production --base-href /hermino.github.io/",
    "watch:landpage": "ng build landpage --watch --configuration development",
    "watch:admin": "ng build admin --watch --configuration development",
    "test": "ng test",
    "lint": "echo 'No linters configured yet'"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "keywords": [
    "portfolio",
    "frontend",
    "developer",
    "react",
    "typescript",
    "angular"
  ],
  "author": "Hermino Freitas <herminojunior@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hermino/hermino.github.io.git"
  },
  "private": true,
  "packageManager": "npm@10.9.3",
  "dependencies": {
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@supabase/supabase-js": "^2.99.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.1",
    "@angular/cli": "^21.1.1",
    "@angular/compiler-cli": "^21.1.0",
    "concurrently": "^9.2.1",
    "jsdom": "^27.1.0",
    "sass": "^1.97.3",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
